{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pull GitHub Issues",
      "type": "shell",
      "command": "python",
      "args": [
        "utility/export-repo-issues.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Populate CRDW Scripts",
      "type": "shell",
      "command": "python",
      "args": [
        "utility/populate-scripts.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}